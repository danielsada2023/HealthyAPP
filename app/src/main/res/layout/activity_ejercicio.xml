<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Crear ejercicio"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <EditText
            android:id="@+id/etNombreEjercicio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nombre del ejercicio"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etDescripcionEjercicio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Descripción"
            android:minLines="3"
            android:gravity="top"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etRepeticiones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Repeticiones"
            android:inputType="number"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etSeries"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Series"
            android:inputType="number"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etDuracion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Duración en minutos"
            android:inputType="number"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etDificultad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Dificultad"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btnSeleccionarImagenEjercicio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Añadir imagen"
            android:layout_marginBottom="12dp" />

        <ImageView
            android:id="@+id/imgEjercicioPreview"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:background="#DDDDDD"
            android:scaleType="centerCrop"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btnSeleccionarVideoEjercicio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Añadir vídeo"
            android:layout_marginBottom="12dp" />

        <VideoView
            android:id="@+id/videoEjercicioPreview"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="#DDDDDD"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btnGuardarEjercicio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Guardar ejercicio" />

    </LinearLayout>

</ScrollView>